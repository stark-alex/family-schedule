# Copy this to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored if it contains secrets — this example file is safe to commit.

aws_region     = "us-east-1"
domain_name    = "starkfamily.com"        # your registered domain
hosted_zone_id = "Z0123456ABCDEFG"        # Route 53 hosted zone ID (from console after registering)

# Subdomains — defaults are fine, change only if you want something different
schedule_subdomain = "schedule"           # → schedule.starkfamily.com
auth_subdomain     = "auth"              # → auth.starkfamily.com (Cognito hosted UI)

project_name = "family-schedule"
